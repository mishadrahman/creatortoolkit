{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(contact-support|privacy-policy|terms-of-service)",
      "destination": "/$1.html"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
