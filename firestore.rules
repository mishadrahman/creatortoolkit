rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidBattle(data) {
      let isBaseValid = data.keys().hasAll(['title', 'thumbA', 'thumbB', 'votesA', 'votesB', 'createdAt'])
        && data.title is string && data.title.size() <= 300
        && data.thumbA is string && data.thumbA.size() <= 2000000 
        && data.thumbB is string && data.thumbB.size() <= 2000000
        && data.votesA is number
        && data.votesB is number
        && data.createdAt is string && data.createdAt.size() <= 50;
      
      let validUser = !data.keys().hasAny(['userId']) || (data.userId is string && data.userId.size() <= 128);
      
      return isBaseValid && validUser;
    }

    function isValidSupportTicket(data) {
      return data.keys().hasAll(['name', 'email', 'subject', 'message', 'userId', 'createdAt', 'status'])
        && data.name is string && data.name.size() <= 150
        && data.email is string && data.email.size() <= 250
        && data.subject is string && data.subject.size() <= 200
        && data.message is string && data.message.size() <= 5000
        && data.userId is string && data.userId.size() <= 128
        && data.createdAt is string && data.createdAt.size() <= 50
        && data.status is string && (data.status == 'open' || data.status == 'closed' || data.status == 'in-progress');
    }

    match /battles/{battleId} {
      allow read: if true;
      
      allow create: if isValidId(battleId) 
        && isValidBattle(incoming()) 
        && incoming().votesA == 0 
        && incoming().votesB == 0;
        
      allow update: if isValidId(battleId) 
        && isValidBattle(incoming())
        && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['votesA']) && incoming().votesA == existing().votesA + 1) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['votesB']) && incoming().votesB == existing().votesB + 1)
        )
        && incoming().title == existing().title
        && incoming().thumbA == existing().thumbA
        && incoming().thumbB == existing().thumbB
        && incoming().createdAt == existing().createdAt
        && incoming().get('userId', '') == existing().get('userId', '');
    }

    match /support_tickets/{ticketId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if isValidSupportTicket(incoming())
        && (
          (request.auth != null && incoming().userId == request.auth.uid) ||
          (request.auth == null && incoming().userId == 'guest')
        );
    }
  }
}
