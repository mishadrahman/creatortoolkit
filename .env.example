# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Supports multiple keys separated by commas for failover / rate-limiting rotation (e.g. key1,key2,key3).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TELEGRAM_BOT_TOKEN: Telegram Bot Token for uploading / storing thumbnail images securely.
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# TELEGRAM_CHAT_ID: Telegram Channel or Group Chat ID where thumbnails are stored.
TELEGRAM_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
